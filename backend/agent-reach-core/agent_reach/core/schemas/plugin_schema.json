{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Manifest Schema",
  "type": "object",
  "required": ["id", "name", "version", "description", "type"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique plugin identifier"
    },
    "name": {
      "type": "string",
      "description": "Human-readable plugin name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "description": "What this plugin does"
    },
    "type": {
      "type": "string",
      "enum": ["agent", "provider", "tool", "planner", "memory", "workflow"],
      "description": "Plugin type"
    },
    "author": {
      "type": "string",
      "description": "Plugin author/team"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "URL for documentation/source"
    },
    "capabilities": {
      "type": "array",
      "items": {"type": "string"},
      "description": "List of capabilities this plugin provides"
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"},
      "description": "List of plugin IDs this plugin depends on"
    },
    "entry_point": {
      "type": "string",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*\\.[a-zA-Z_][a-zA-Z0-9_]*:[A-Za-z_][a-zA-Z0-9_]*$",
      "description": "Python module:class path for the plugin"
    },
    "config_schema": {
      "type": "object",
      "description": "JSON schema for plugin configuration"
    }
  }
}
